# ==============================================================================
# Frontend (Next.js dashboard_client_web) — environment variables
# ==============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.
#
# Next.js env vars exposed to the browser MUST be prefixed with NEXT_PUBLIC_.
# Server-only vars (no prefix) are available in Server Components / Route
# Handlers / middleware only and are NEVER bundled into the browser.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# Architecture A-1 (Supabase server-only):
#   Supabase is server-only — the browser never holds Supabase keys.
#   Data comes via the Express API (NEXT_PUBLIC_API_BASE).
#   Do NOT add any NEXT_PUBLIC_SUPABASE_* or SUPABASE_* keys here.
#   All DB access goes through apps/dashboard_server, which holds SUPABASE_SECRET_KEY.

# ------------------------------------------------------------------------------
# App — runtime and identity
# NODE_ENV is set automatically by Next.js / Vercel; override only if needed.
# NEXT_PUBLIC_SITE_URL  : canonical URL for the app (OG tags, canonical links).
# NEXT_PUBLIC_APP_NAME  : human-readable product name used in titles/metadata.
# NEXT_PUBLIC_ENABLE_ANALYTICS: toggle client-side analytics (true | false).
# ------------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=TradeLunch
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ------------------------------------------------------------------------------
# Backend API — base URL for the Express dashboard_server
# Local dev : http://localhost:4000
# Production: your deployed Express API URL (e.g. https://api.tradelunch.com)
# All data fetching (Supabase / DB reads) routes through this endpoint.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:4000

# ------------------------------------------------------------------------------
# Dashboard data source switch (read by env.schema.ts).
# Absent → 'mock' (live behavior unchanged); set 'backend' to read the Express API.
# ------------------------------------------------------------------------------
DASHBOARD_DATA_SOURCE=mock

# ------------------------------------------------------------------------------
# CDN — public URL for post assets (Supabase Storage public bucket in Phase B)
# Mirrors CDN_ASSET_POSTS on the server side.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CDN_ASSET_POSTS=https://posts.example.com

# ------------------------------------------------------------------------------
# Google site verification / AdSense (read in app/layout.tsx with '' fallback).
# Optional — leave blank to omit the meta tags.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SEARCH_ENGINE=
NEXT_PUBLIC_GOOGLE_ADSENSE=

# ------------------------------------------------------------------------------
# Clerk — authentication. The Next.js app needs BOTH keys:
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY — browser + server (ClerkProvider, SDK).
#   CLERK_SECRET_KEY                  — server-only: clerkMiddleware /
#                                       auth.protect() / auth().getToken().
#     No NEXT_PUBLIC_ prefix, so it is never shipped to the browser bundle.
#     This is the SAME sk_ secret value used by the Express dashboard_server
#     runtime — keep both apps in sync.
# Dashboard: https://dashboard.clerk.com → app → API Keys
#
# URL vars route Clerk's hosted components to the local /sign-in & /sign-up pages:
#   NEXT_PUBLIC_CLERK_SIGN_IN_URL       : path to the sign-in page
#   NEXT_PUBLIC_CLERK_SIGN_UP_URL       : path to the sign-up page
#   NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL : where to send users after sign-in
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
