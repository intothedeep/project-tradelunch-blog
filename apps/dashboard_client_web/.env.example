# ==============================================================================
# Frontend (Next.js) — environment variables
# ==============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.
#
# Next.js env vars exposed to the browser MUST be prefixed with NEXT_PUBLIC_.
# Server-only vars (no prefix) are available in Server Components and Route Handlers only.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ------------------------------------------------------------------------------
# Server runtime (set automatically by Next.js / Vercel — override only if needed)
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST_NAME=localhost

# ------------------------------------------------------------------------------
# Backend API — base URL for the Express dashboard_server
# Local dev : http://localhost:4000
# Production: your Vercel backend project URL (e.g. https://tradelunch-api.vercel.app)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:4000

# ------------------------------------------------------------------------------
# CDN — public URL for post assets (S3 now; Supabase Storage in Phase B)
# Production: set to your CDN or Supabase Storage public bucket URL
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CDN_ASSET_POSTS=https://posts.prettylog.com
