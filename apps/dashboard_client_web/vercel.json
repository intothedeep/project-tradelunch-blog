{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=dashboard_client_web...",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
