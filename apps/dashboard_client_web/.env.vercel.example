# =============================================================================
# Vercel Project #1 — FRONTEND (root dir: apps/dashboard_client_web)
# Paste into Vercel → Settings → Environment Variables → Production.
# Replace every <...>. No real secrets in this file.
# Verified 2026-06-25 against env.schema.ts + apis/axios_instance.ts + app/layout.tsx.
# =============================================================================

# --- REQUIRED ---
# THE backend URL the client calls (env.schema.ts → API_BASE → axios baseURL).
# Zod .url() — must be a valid absolute URL. This is the dashboard_server Vercel
# project (taeklim-blog-server::darkowlrising); override in the Vercel dashboard.
NEXT_PUBLIC_API_BASE=https://blogapi.prettylog.com

# --- RECOMMENDED ---
NEXT_PUBLIC_SITE_URL=https://my.prettylog.com
NEXT_PUBLIC_APP_NAME=TradeLunch
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# --- OPTIONAL ---
# NEXT_PUBLIC_CDN_ASSETS is Zod .url(): if set it MUST be a valid URL — NEVER "".
# Leave UNSET until Phase B (defaults to https://blog-assets.prettylog.com).
# NEXT_PUBLIC_CDN_ASSETS=https://<project-ref>.supabase.co/storage/v1/object/public/blog-assets.prettylog.com/

# Google site verification / AdSense (layout.tsx reads with '' fallback)
# NEXT_PUBLIC_GOOGLE_SEARCH_ENGINE=
# NEXT_PUBLIC_GOOGLE_ADSENSE=

# --- PHASE D (Clerk auth — leave UNSET for Phase A) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...                 # server-side: middleware + Server Actions
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- DO NOT SET on the frontend ---
#   SUPABASE_*, DATABASE_URL  → never expose DB / Supabase secrets to the client bundle
#   POSTGRES_*                → DB credentials; never inject on the frontend project
