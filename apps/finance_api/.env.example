# finance_api — required environment variables
# Copy to .env for local dev; .env.production for Oracle VM deploy.

NODE_ENV=development
PORT=4000
HOST_NAME=localhost

# Postgres — SAME var names as the rest of the repo (Vercel↔Supabase injects
# these). Value differs per env: Supabase locally, Oracle VM PG17 in prod.
# Pooled URL for runtime queries (pg Pool).
POSTGRES_URL=postgresql://user:password@host:6543/postgres

# Direct/session URL for migrations (no pooler).
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/postgres

# Clerk — secret key for Express request authentication via @clerk/express.
CLERK_SECRET_KEY=sk_test_...

# CORS — comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3002
APP_URL=http://localhost:3002
