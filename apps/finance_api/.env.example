# finance_api — required environment variables
# Copy to .env for local dev; .env.production for Oracle VM deploy.

NODE_ENV=development
PORT=4000
HOST_NAME=localhost

# Finance Postgres (Oracle VM PG17 instance).
# Pooled URL for runtime queries (pg Pool).
FINANCE_POSTGRES_URL=postgresql://user:password@host:5432/finance_db

# Direct/session URL for migrations (no pooler).
FINANCE_POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/finance_db

# Clerk — secret key for Express request authentication via @clerk/express.
CLERK_SECRET_KEY=sk_test_...

# CORS — comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3002
APP_URL=http://localhost:3002
