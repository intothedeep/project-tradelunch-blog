# Copy to `.env` and fill real values. Loaded via python-dotenv.
# Do NOT quote or leave empty (empty == unset).

# ── Supabase Postgres (serving) ─────────────────────────────────────────
# REQUIRED. Supavisor SESSION pooler (IPv4) — NOT the direct db.<ref> host
# (IPv6-only, fails on IPv4 GitHub runners).
#   aws-0-<region>.pooler.supabase.com:5432
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Supabase Storage (Parquet archive — Phase 1.5 only) ─────────────────
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE=your-service-role-key

# ── Provider tuning (optional) ──────────────────────────────────────────
# YAHOO_RPM=30
