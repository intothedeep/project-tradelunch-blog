# Environment Variables Example
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ==================== Environment ====================
NODE_ENV=development

# ==================== LLM Configuration ====================
LLM_PROVIDER=local  # local, openai, anthropic

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Common LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ==================== Supabase Storage (native client) ====================
# Project Settings -> API. SUPABASE_SECRET_KEY is the service-role/secret key.
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_STORAGE_BUCKET=blog.prettylog
SUPABASE_PUBLISHABLE_KEY=...        # backend unused (client-side only)

# ==================== PostgreSQL Database ====================
# blog_agent runs as an asyncpg CLI and PREFERS the DIRECT (non-pooling, port 5432)
# connection — it uses long-lived multi-statement sessions. The pooled connection
# (port 6543, PgBouncer transaction pooler) is fallback only.
# sslmode/pgbouncer/connect_timeout are stripped and TLS is non-verifying
# (mirrors the TS server's rejectUnauthorized:false).
#
# Resolution order (first non-empty wins):
#   POSTGRES_URL_NON_POOLING -> POSTGRES_URL
#
# These are AUTO-INJECTED on Vercel by the Supabase integration, but are NOT
# created automatically in local .env — set them MANUALLY here. For local
# `supabase start`, point both at 127.0.0.1:54322
# (postgresql://postgres:postgres@127.0.0.1:54322/postgres).
#
# Direct (preferred): postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Pooled (fallback) : postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=
# POSTGRES_PRISMA_URL — IGNORED (Prisma-only; ?pgbouncer/connect_timeout break asyncpg).
# Supabase ALSO auto-injects four DISCRETE parts (POSTGRES_USER / POSTGRES_HOST /
# POSTGRES_PASSWORD / POSTGRES_DATABASE) plus POSTGRES_PORT — kept here for parity
# with what the integration provides. They are redundant with the URLs above and NOT
# read by configs/database.py (it resolves from POSTGRES_URL_NON_POOLING -> POSTGRES_URL
# only); do not reintroduce DB_PG_*-style discrete config (retired in Phase B5).
# POSTGRES_PORT is the DIRECT (5432) port only; the pooled 6543 lives inside
# POSTGRES_URL and cannot be a single scalar — so the URLs stay authoritative.
POSTGRES_USER=postgres
POSTGRES_HOST=db.<project-ref>.supabase.co
POSTGRES_PASSWORD=<db-password>
POSTGRES_DATABASE=postgres
POSTGRES_PORT=5432
#
# DB_ECHO=false   # set true to echo all SQLAlchemy SQL (read by db/connection.py; default false)

# ==================== CDN Configuration ====================
# Public base for stored objects; stored_uri = ${CDN_ASSETS}/<key>
CDN_ASSETS=https://assets.prettylog.com

# ==================== Domain Configuration ====================
SITE_DOMAIN=http://localhost:3000
API_SITE_DOMAIN=https://my-api.prettylog.com
BLOG_BASE_URL=https://my.prettylog

# ==================== User Configuration ====================
DEFAULT_USER_ID=1
DEFAULT_USERNAME=taeklim
# SNOWFLAKE_MACHINE_ID=1   # worker id for snowflake id generation (read by utils/snowflake.py; default 1)

# ==================== MCP Configuration ====================
MCP_SERVER_PATH=./mcp-server/build/index.js
MCP_ENABLED=false

# ==================== Logging ====================
LOG_LEVEL=INFO

# ==================== Legacy (AWS RDS/S3) — retired in Phase B5 ====================
# AWS_REGION=us-west-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_S3_BUCKET=my-blog-bucket
# S3_REGION=us-west-1
# AWS_RDS_CA=
# DB_PG_HOST=localhost
# DB_PG_PORT=5432
# DB_PG_DATABASE=tradelunch
# DB_PG_USER=super
# DB_PG_PASSWORD=your-password
# DB_SSL_ENABLED=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_PATH=configs/certs/rds-combined-ca-bundle.pem
# EC2_HOST=
# EC2_PORT=22
# EC2_USERNAME=ec2-user

# --- Storage (provider-swappable; see apps/dashboard_server/src/lib/storage/CONTRACT.md) ---
STORAGE_PROVIDER=supabase                 # supabase | oci | s3
STORAGE_ENDPOINT=                         # oci/s3 only, e.g. https://<namespace>.compat.objectstorage.ap-chuncheon-1.oraclecloud.com
STORAGE_ACCESS_KEY=                        # oci/s3 only (OCI Customer Secret Key)
STORAGE_SECRET_KEY=                        # oci/s3 only
STORAGE_REGION=                            # oci/s3 only, e.g. ap-chuncheon-1
STORAGE_BUCKET=blog.prettylog             # MUST stay blog.prettylog (else files.stored_uri rewrite)
