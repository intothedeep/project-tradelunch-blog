# Environment Variables Example
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ==================== Environment ====================
NODE_ENV=development

# ==================== LLM Configuration ====================
LLM_PROVIDER=local  # local, openai, anthropic

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Common LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ==================== Supabase Storage (S3-compatible) ====================
# Project Settings -> Storage -> S3 access keys
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key

# Storage bucket (defaults to blog.prettylog)
SUPABASE_S3_BUCKET=blog.prettylog

# ==================== PostgreSQL Database (Supabase pooler) ====================
# Single connection string; sslmode is stripped and TLS is non-verifying
# (mirrors the TS server's rejectUnauthorized:false).
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ==================== CDN Configuration ====================
# Public base for stored objects; stored_uri = ${CDN_ASSETS}/<key>
CDN_ASSETS=https://assets.prettylog.com

# ==================== Domain Configuration ====================
SITE_DOMAIN=http://localhost:3000
API_SITE_DOMAIN=https://my-api.prettylog.com
BLOG_BASE_URL=https://my.prettylog

# ==================== User Configuration ====================
DEFAULT_USER_ID=2
DEFAULT_USERNAME=taeklim

# ==================== MCP Configuration ====================
MCP_SERVER_PATH=./mcp-server/build/index.js
MCP_ENABLED=false

# ==================== Logging ====================
LOG_LEVEL=INFO

# ==================== Legacy (AWS RDS/S3) — retired in Phase B5 ====================
