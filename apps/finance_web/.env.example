# finance_web — required environment variables
# Copy to .env.local for local dev.

# Finance API (Oracle VM / Express) — NEXT_PUBLIC_ makes it available in the client bundle.
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Clerk — obtain from clerk.com dashboard.
# Use DEVELOPMENT keys for local, PRODUCTION keys on deploy target.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
