{
    "extends": "@repo/typescript-config/nextjs.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "rootDir": ".",
        "allowJs": true,
        "paths": {
            "@": ["."],
            "@/*": ["./*"]
        },
        "typeRoots": ["node_modules/@types", "types"]
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "next-env.d.ts",
        ".next/types/**/*.ts",
        "types/**/*",
        "**/*.d.ts"
    ],
    "exclude": ["node_modules", "dist", "coverage", "**/x_*"]
}
