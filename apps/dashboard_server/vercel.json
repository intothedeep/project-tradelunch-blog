{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "tsc && tsc-alias",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "dist/api/index.js": {
      "runtime": "@vercel/node@5"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/dist/api/index.js"
    }
  ]
}
