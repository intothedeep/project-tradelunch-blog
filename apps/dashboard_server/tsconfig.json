{
    "// vercel-note": "Self-contained on purpose. Vercel @vercel/node bundles ts-node@10.9.1, which CANNOT resolve `extends` to a workspace package under TS>=5.3 — it silently drops inherited strict/strictNullChecks, breaking discriminated-union narrowing (TS2339). Inline all compiler options here; do NOT reintroduce `extends`.",
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "composite": false,
        "ignoreDeprecations": "5.0",
        "outDir": "dist",
        "rootDir": ".",
        "baseUrl": ".",
        "paths": {
            "@": ["."],
            "@/*": ["./*"]
        },
        "typeRoots": ["node_modules/@types", "types"]
    },
    "include": [
        "api/**/*",
        "src/utils/**/*",
        "src/**/*",
        "types/**/*",
        "types/global.d.ts",
        "**/*.d.ts",
        "**/lib/*",
        "config"
    ],
    "// note": "Offline publish tooling retired — superseded by apps/blog_agent (markdown→DB + Supabase Storage). Old scripts archived as x_scripts/ and excluded via **/x_*.",
    "exclude": ["node_modules", "dist", "coverage", "**/x_*"]
}

