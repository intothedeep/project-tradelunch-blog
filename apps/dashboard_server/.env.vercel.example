# =============================================================================
# Vercel Project #2 — BACKEND (root dir: apps/dashboard_server)
# Paste into Vercel → Settings → Environment Variables → Production.
# Replace every <...>. This file holds NO real secrets; do not put secrets here.
# Verified 2026-06-26 against src/config/env.schema.ts + src/database.ts.
# =============================================================================

# --- REQUIRED ---
NODE_ENV=production

# DB connection for the pg Pool. The Vercel↔Supabase integration auto-injects
# POSTGRES_URL (pooled, 6543) + POSTGRES_URL_NON_POOLING (direct, 5432) and the
# server uses them automatically — you do NOT need to set them by hand when the
# integration is installed. Only set them manually if you are NOT using it:
# POSTGRES_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# CORS allowlist, comma-separated (server.ts splits on ','). Must list the frontend
# origins or the browser-side /dashboard calls are blocked by CORS.
ALLOWED_ORIGINS=https://<frontend-project>.vercel.app,https://my.prettylog.com

# --- RECOMMENDED (code has defaults, but set explicitly for prod) ---
APP_URL=https://my.prettylog.com
SITE_DOMAIN=https://my.prettylog.com
DEFAULT_USER_ID=2

# Direct connection, port 5432 — migrations only. Auto-injected by the integration
# as POSTGRES_URL_NON_POOLING; set manually only if not using the integration.
# POSTGRES_URL_NON_POOLING=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- PHASE B (leave UNSET until the Supabase Storage bucket exists) ---
# CDN_ASSETS=https://<project-ref>.supabase.co/storage/v1/object/public/blog-assets.prettylog.com/

# --- PHASE D (Clerk auth — leave UNSET for Phase A) ---
# CLERK_SECRET_KEY=sk_...

# --- DO NOT SET (AWS deleted; these have safe defaults or are unused) ---
#   AWS_*, EC2_*, DB_PG_*   → not needed
#   SUPABASE_*              → only if a supabase-js path is added later; blog reads use POSTGRES_URL only
#   API_SITE_DOMAIN         → removed (was dead); the client uses NEXT_PUBLIC_API_BASE instead
#   POSTGRES_PRISMA_URL     → injected by the integration but unused (Prisma-only ?pgbouncer param)
#   POSTGRES_USER/HOST/PASSWORD/DATABASE → auto-injected, redundant, unused (code reads the URLs)
