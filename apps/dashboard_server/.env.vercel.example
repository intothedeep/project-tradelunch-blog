# =============================================================================
# Vercel Project #2 — BACKEND (root dir: apps/dashboard_server)
# Paste into Vercel → Settings → Environment Variables → Production.
# Replace every <...>. This file holds NO real secrets; do not put secrets here.
# Verified 2026-06-25 against src/config/env.schema.ts + src/database.ts.
# =============================================================================

# --- REQUIRED ---
NODE_ENV=production

# DB connection for the pg Pool. If the Vercel↔Supabase integration is installed,
# it auto-injects POSTGRES_URL (pooled, 6543) + POSTGRES_URL_NON_POOLING (direct, 5432)
# and the server uses them automatically — you do NOT need to set DATABASE_URL by hand.
# Only set DATABASE_URL manually if you are NOT using the integration:
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# CORS allowlist, comma-separated (server.ts splits on ','). Must list the frontend
# origins or the browser-side /dashboard calls are blocked by CORS.
ALLOWED_ORIGINS=https://<frontend-project>.vercel.app,https://my.prettylog.com

# --- RECOMMENDED (code has defaults, but set explicitly for prod) ---
APP_URL=https://my.prettylog.com
SITE_DOMAIN=https://my.prettylog.com
DEFAULT_USER_ID=2

# Direct connection, port 5432 — migrations only. Covered by the integration's
# POSTGRES_URL_NON_POOLING; set manually only if not using the integration.
# DATABASE_URL_DIRECT=postgresql://postgres.<project-ref>:<db-password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- PHASE B (leave UNSET until the Supabase Storage bucket exists) ---
# CDN_ASSETS=https://<project-ref>.supabase.co/storage/v1/object/public/blog.prettylog/

# --- PHASE D (Clerk auth — leave UNSET for Phase A) ---
# CLERK_SECRET_KEY=sk_...

# --- DO NOT SET (AWS deleted; these have safe defaults or are unused) ---
#   AWS_*, EC2_*, DB_PG_*   → not needed
#   SUPABASE_*              → only if a supabase-js path is added later; blog reads use DATABASE_URL only
#   API_SITE_DOMAIN         → removed (was dead); the client uses NEXT_PUBLIC_API_BASE instead
