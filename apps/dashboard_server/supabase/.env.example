# ==============================================================================
# Supabase project / CLI — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.
#
# Values are found in the Supabase Dashboard:
#   https://supabase.com/dashboard → select your project → Project Settings

# ------------------------------------------------------------------------------
# Project ref — unique identifier for your Supabase project.
# Dashboard: Settings → General → Reference ID
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_REF=abcdefghijklmnopqrst

# ------------------------------------------------------------------------------
# DB password — the password you set when creating the project.
# Dashboard: Settings → Database → Database password
# ------------------------------------------------------------------------------
SUPABASE_DB_PASSWORD=your-db-password-here

# ------------------------------------------------------------------------------
# Supabase project URL — used by the JS client SDK and server-side calls.
# Dashboard: Settings → API → Project URL
# ------------------------------------------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co

# ------------------------------------------------------------------------------
# Anon / publishable key — safe to expose in the browser.
# Dashboard: Settings → API → Project API keys → anon / public
# ------------------------------------------------------------------------------
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------------------------
# Service role / secret key — SERVER ONLY. Never expose to the browser.
# Used for admin-level operations that bypass Row Level Security.
# Dashboard: Settings → API → Project API keys → service_role
# ------------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------------------------
# Connection strings
#
# DIRECT (port 5432) — use for:
#   • supabase db push / pull (migrations via Supabase CLI)
#   • psql / pgAdmin administration
#   • long-lived server processes with persistent connections
#
# POOLER / Transaction mode (port 6543, PgBouncer) — use for:
#   • Vercel serverless functions (short-lived, no persistent connections)
#   • Any runtime with high connection churn
#
# Dashboard: Settings → Database → Connection string
#   → toggle "Transaction pooler" for 6543, "Direct connection" for 5432
# ------------------------------------------------------------------------------

# Direct connection (migrations, CLI, psql)
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Transaction pooler — use this as DATABASE_URL in apps/dashboard_server/.env
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
