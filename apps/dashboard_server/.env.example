# ==============================================================================
# Backend (Express dashboard_server) — environment variables
# ==============================================================================
# Copy this file to `.env` (local dev) or set vars in your deployment platform.
# `.env` and `.env.production` are gitignored.
#
# Architecture A-1: ALL Supabase keys live here only (server-side).
# Clerk: this server needs ONLY CLERK_SECRET_KEY (JWT verification). The Next.js
# client (dashboard_client_web) holds the publishable key AND the same secret
# key for its own server runtime — keep CLERK_SECRET_KEY in sync across both.

# ------------------------------------------------------------------------------
# Server runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST_NAME=localhost

# ------------------------------------------------------------------------------
# Domains
# SITE_DOMAIN    : canonical frontend URL (used for CORS + redirect generation)
# APP_URL        : frontend origin (also used in generated links / alerts)
# ALLOWED_ORIGINS: comma-separated list of origins allowed by CORS middleware
#   Local dev  : http://localhost:3001
#   Production : https://tradelunch.com,https://www.tradelunch.com
# ------------------------------------------------------------------------------
SITE_DOMAIN=http://localhost:3001
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# ------------------------------------------------------------------------------
# CDN — public URL for post assets (mirrors NEXT_PUBLIC_CDN_ASSET_POSTS on client)
# ------------------------------------------------------------------------------
CDN_ASSET_POSTS=https://posts.example.com/

# ------------------------------------------------------------------------------
# App defaults
# DEFAULT_USER_ID: fallback author id for unauthenticated/server writes.
# ------------------------------------------------------------------------------
DEFAULT_USER_ID=2

# ------------------------------------------------------------------------------
# Supabase (server-only; A-1) — NEVER expose these to the browser or client app.
# Two ways to run: CLOUD (default below) or LOCAL via `supabase start`.
#
# CLOUD — Dashboard: https://supabase.com/dashboard → Project Settings
#   SUPABASE_PROJECT_ID : Settings → General → Reference ID (key name is _ID, not _REF)
#   SUPABASE_DB_PASSWORD: Settings → Database → Database password
#   SUPABASE_URL        : Settings → API → Project URL
#   SUPABASE_SECRET_KEY : Settings → API → Project API keys → secret key
#                         (Supabase 2024+ naming; formerly SUPABASE_SERVICE_ROLE_KEY)
#
# LOCAL (`supabase start`) — values from supabase/config.toml + `supabase status`:
#   SUPABASE_PROJECT_ID=dashboard_server          # matches config.toml project_id
#   SUPABASE_DB_PASSWORD=postgres
#   SUPABASE_URL=http://127.0.0.1:54321           # [api] port; use 127.0.0.1, NOT localhost (IPv4)
#   SUPABASE_SECRET_KEY=sb_secret_...             # from `supabase status` output
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# Connection strings
#
# DATABASE_URL_DIRECT (port 5432) — use for:
#   • supabase db push / pull (migrations via Supabase CLI)
#   • psql / pgAdmin / manual administration
#   • long-lived server processes with persistent connections
#
# DATABASE_URL (port 6543, PgBouncer transaction pooler) — use for:
#   • all runtime queries in serverless / pooled environments
#   • Vercel functions, short-lived Lambda-style handlers
#
# CLOUD — Dashboard: Settings → Database → Connection string
#   → toggle "Transaction pooler" for 6543, "Direct connection" for 5432
#
# LOCAL (`supabase start`) — both point at the local db (port 54322 in config.toml):
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   DATABASE_URL_DIRECT=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# ------------------------------------------------------------------------------
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[db-password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# On Vercel, the Supabase integration auto-injects these and they take precedence
# over DATABASE_URL / DATABASE_URL_DIRECT (see env.schema.ts). Leave unset locally.
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# ------------------------------------------------------------------------------
# Clerk (server) — server-side JWT verification (resolveAuth middleware via
# @clerk/express verifyToken). This server uses ONLY the secret key; it does NOT
# read the publishable key. Same sk_ value as the Next.js client's server runtime.
# Dashboard: https://dashboard.clerk.com → app → API Keys → Secret keys
#
# CLERK_WEBHOOK_SECRET : verifies Clerk → server webhook signatures (user provisioning).
# ALLOW_OPEN_SIGNUP    : 'true' provisions new users without an invite (open self-signup).
# ------------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=
ALLOW_OPEN_SIGNUP=false

# ------------------------------------------------------------------------------
# Build provenance — stamped into logs/diagnostics to trace which build
# processed a request. On Vercel set to ${VERCEL_GIT_COMMIT_SHA}.
# Falls back to "local" when unset.
# ------------------------------------------------------------------------------
GIT_SHA=

# ------------------------------------------------------------------------------
# File upload
# MAX_FILE_SIZE      : maximum upload size in bytes (e.g. 10485760 = 10 MB)
# ALLOWED_FILE_TYPES : comma-separated list of permitted MIME types
# ------------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ------------------------------------------------------------------------------
# Image processing — dimensions and quality targets for server-side thumbnailing
# THUMBNAIL_WIDTH / THUMBNAIL_HEIGHT : target thumbnail dimensions (pixels)
# THUMBNAIL_QUALITY                  : JPEG quality for thumbnails (1–100)
# IMAGE_OPTIMIZATION_QUALITY        : JPEG quality for general optimised output
# MAX_IMAGE_WIDTH / MAX_IMAGE_HEIGHT : hard cap before resizing (pixels)
# ------------------------------------------------------------------------------
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
THUMBNAIL_QUALITY=80
IMAGE_OPTIMIZATION_QUALITY=85
MAX_IMAGE_WIDTH=1920
MAX_IMAGE_HEIGHT=1080

# ------------------------------------------------------------------------------
# [DEFERRED] Cron authentication — required when ingestion cron is added (Phase C+)
# CRON_SECRET gates /api/cron/* routes; without it the route returns 401.
# Generate: openssl rand -hex 32
# Uncomment when the cron routes are implemented.
# ------------------------------------------------------------------------------
# CRON_SECRET=

# ==============================================================================
# [LEGACY] — removed in Phase B (S3 → Supabase Storage) / once fully on Supabase
# These keys were used before the Supabase migration and are no longer read by
# any src/ code. Kept commented so the transition stays auditable without
# hunting through git history.
# ==============================================================================

# AWS S3 / CloudFront — asset storage + CDN before Supabase Storage migration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# CLOUDFRONT_DOMAIN=https://dxxxxxxxxxxxxxx.cloudfront.net

# EC2 / SSH tunnel — used for SSH tunnel to AWS RDS before Supabase
# EC2_HOST=
# EC2_PORT=22
# EC2_USERNAME=ec2-user

# Direct Postgres (self-hosted RDS) — replaced by Supabase connection strings above
# DB_PG_HOST=localhost
# DB_PG_DATABASE=
# DB_PG_USER=
# DB_PG_PASSWORD=
# DB_PG_PORT=5432
