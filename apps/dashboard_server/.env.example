# ==============================================================================
# Backend (Express dashboard_server) — environment variables
# ==============================================================================
# Copy this file to `.env` (local dev) or set vars in your deployment platform.
# `.env` and `.env.production` are gitignored.
#
# Architecture A-1: ALL Supabase keys and CLERK_SECRET_KEY live here only.
# The Next.js client (dashboard_client_web) holds ONLY the Clerk publishable key.

# ------------------------------------------------------------------------------
# Server runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST_NAME=localhost

# ------------------------------------------------------------------------------
# Domains
# SITE_DOMAIN    : canonical frontend URL (used for CORS + redirect generation)
# APP_URL        : frontend origin (also used in generated links / alerts)
# ALLOWED_ORIGINS: comma-separated list of origins allowed by CORS middleware
#   Local dev  : http://localhost:3001
#   Production : https://tradelunch.com,https://www.tradelunch.com
# ------------------------------------------------------------------------------
SITE_DOMAIN=http://localhost:3001
API_SITE_DOMAIN=http://localhost:4000
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# ------------------------------------------------------------------------------
# CDN — public URL for post assets (mirrors NEXT_PUBLIC_CDN_ASSET_POSTS on client)
# ------------------------------------------------------------------------------
CDN_ASSET_POSTS=https://posts.example.com/

# ------------------------------------------------------------------------------
# App defaults
# ------------------------------------------------------------------------------
DEFAULT_USER_ID=1

# ------------------------------------------------------------------------------
# Supabase (server-only; A-1) — NEVER expose these to the browser or client app.
# Dashboard: https://supabase.com/dashboard → Project Settings
# SUPABASE_PROJECT_ID : Settings → General → Reference ID
#                       (note: key name is _ID, not _REF)
# SUPABASE_DB_PASSWORD: Settings → Database → Database password
# SUPABASE_URL        : Settings → API → Project URL
# SUPABASE_SECRET_KEY : Settings → API → Project API keys → secret key
#   (Supabase 2024+ naming; formerly SUPABASE_SERVICE_ROLE_KEY)
#   macOS/Colima: use 127.0.0.1, NOT localhost (IPv6 vs IPv4 binding issue).
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# Connection strings
#
# DATABASE_URL_DIRECT (port 5432) — use for:
#   • supabase db push / pull (migrations via Supabase CLI)
#   • psql / pgAdmin / manual administration
#   • long-lived server processes with persistent connections
#
# DATABASE_URL (port 6543, PgBouncer transaction pooler) — use for:
#   • all runtime queries in serverless / pooled environments
#   • Vercel functions, short-lived Lambda-style handlers
#
# Dashboard: Settings → Database → Connection string
#   → toggle "Transaction pooler" for 6543, "Direct connection" for 5432
# ------------------------------------------------------------------------------
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[db-password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------------------
# Clerk (server) — server-side JWT verification (clerkAuth middleware)
# Dashboard: https://dashboard.clerk.com → app → API Keys → Secret keys
# The NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY lives in dashboard_client_web — not here.
# ------------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_...

# ------------------------------------------------------------------------------
# Build provenance — stamped into logs/diagnostics to trace which build
# processed a request. On Vercel set to ${VERCEL_GIT_COMMIT_SHA}.
# Falls back to "unknown" when unset.
# ------------------------------------------------------------------------------
GIT_SHA=

# ------------------------------------------------------------------------------
# File upload
# MAX_FILE_SIZE      : maximum upload size in bytes (e.g. 10485760 = 10 MB)
# ALLOWED_FILE_TYPES : comma-separated list of permitted MIME extensions
# ------------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,svg,pdf

# ------------------------------------------------------------------------------
# CDN / CloudFront — distribution domain for served assets
# Dashboard: AWS CloudFront → your distribution → Domain name
# ------------------------------------------------------------------------------
CLOUDFRONT_DOMAIN=https://dxxxxxxxxxxxxxx.cloudfront.net

# ------------------------------------------------------------------------------
# Image processing — dimensions and quality targets for server-side thumbnailing
# THUMBNAIL_WIDTH / THUMBNAIL_HEIGHT : target thumbnail dimensions (pixels)
# THUMBNAIL_QUALITY                  : JPEG quality for thumbnails (1–100)
# IMAGE_OPTIMIZATION_QUALITY        : JPEG quality for general optimised output
# MAX_IMAGE_WIDTH / MAX_IMAGE_HEIGHT : hard cap before resizing (pixels)
# ------------------------------------------------------------------------------
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
THUMBNAIL_QUALITY=80
IMAGE_OPTIMIZATION_QUALITY=85
MAX_IMAGE_WIDTH=2000
MAX_IMAGE_HEIGHT=2000

# ------------------------------------------------------------------------------
# [DEFERRED] Cron authentication — required when ingestion cron is added (Phase C+)
# CRON_SECRET gates /api/cron/* routes; without it the route returns 401.
# Generate: openssl rand -hex 32
# Uncomment when the cron routes are implemented.
# ------------------------------------------------------------------------------
# CRON_SECRET=

# ==============================================================================
# [LEGACY] — removed in Phase B (S3 → Supabase Storage) / once fully on Supabase
# These keys were used before the Supabase migration and can be deleted once
# all code paths no longer reference them. Kept here so the transition is
# auditable without hunting through git history.
# ==============================================================================

# AWS S3 — asset storage before Supabase Storage migration (Phase B)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# EC2 / SSH tunnel — used for SSH tunnel to AWS RDS before Supabase
# EC2_HOST=
# EC2_PORT=22
# EC2_USERNAME=ec2-user

# Direct Postgres (self-hosted RDS) — replaced by Supabase connection strings above
# DB_PG_HOST=localhost
# DB_PG_DATABASE=
# DB_PG_USER=
# DB_PG_PASSWORD=
# DB_PG_PORT=5432
