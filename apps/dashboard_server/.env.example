# ==============================================================================
# Backend (Express dashboard_server) — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# ------------------------------------------------------------------------------
# Server runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST_NAME=localhost

# ------------------------------------------------------------------------------
# Domains
# ------------------------------------------------------------------------------
SITE_DOMAIN=http://localhost:3000
API_SITE_DOMAIN=https://my-api.prettylog.com

# ------------------------------------------------------------------------------
# DATABASE_URL — Supabase transaction pooler (port 6543, PgBouncer)
# Use this for all runtime queries in Vercel serverless / Edge functions.
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
# Format: postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------------------
# Legacy DB_PG_* vars — replaced by DATABASE_URL once migrated to Supabase.
# Keep for local dev against a direct Postgres instance. Remove after migration.
# ------------------------------------------------------------------------------
DB_PG_HOST=localhost
DB_PG_DATABASE=db20250627
DB_PG_USER=super
DB_PG_PASSWORD=
DB_PG_PORT=5432

# ------------------------------------------------------------------------------
# EC2 / SSH tunnel vars — legacy, used for SSH tunnel to AWS RDS.
# These will be removed when the SSH tunnel is dropped (Supabase uses direct TLS).
# ------------------------------------------------------------------------------
EC2_HOST=13.57.82.45
EC2_PORT=22
EC2_USERNAME=ec2-user

# ------------------------------------------------------------------------------
# AWS S3 — legacy asset storage. Will be removed in Phase B (S3 → Supabase Storage).
# Until Phase B, these remain required to serve post assets via CDN.
# ------------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=my-posts-bucket

# ------------------------------------------------------------------------------
# Supabase — Phase B storage (S3 → Supabase Storage).
# Add these when migrating from S3. Not required until Phase B.
# Dashboard: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------------------------
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # secret — never expose to frontend

# ------------------------------------------------------------------------------
# CDN — public URL for post assets (S3 now; Supabase Storage public URL in Phase B)
# ------------------------------------------------------------------------------
CDN_ASSET_POSTS=https://posts.prettylog.com/

# ------------------------------------------------------------------------------
# App defaults
# ------------------------------------------------------------------------------
DEFAULT_USER_ID=2
