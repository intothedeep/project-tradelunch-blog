#!/usr/bin/env bash
# scripts/migration/00_env.sh — sourced by every migration script.
# Copy to `00_env.sh` and fill in. NEVER commit the filled copy (it holds live secrets).
#   cp 00_env.sh.example 00_env.sh && $EDITOR 00_env.sh
# All scripts do: `source "$(dirname "$0")/00_env.sh"`.

set -euo pipefail

# ── Source: current Supabase project (SRC) — the one being emptied ────────────
export SRC_POOLED="postgresql://postgres.rdtvemrbbsmiagbyvgzz:PW@aws-0-REGION.pooler.supabase.com:6543/postgres"
export SRC_NON_POOLING="postgresql://postgres.rdtvemrbbsmiagbyvgzz:PW@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Destination A: NEW Supabase project (blog DB lands here) ──────────────────
export DST_SB_POOLED="postgresql://postgres.NEWREF:PW@aws-0-REGION.pooler.supabase.com:6543/postgres"
export DST_SB_NON_POOLING="postgresql://postgres.NEWREF:PW@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Destination B: Oracle PG17 (finance DB lands here) ────────────────────────
# Direct/session 5432 for restore + collector. PgBouncer 6432 for app pools (see 23_pgbouncer_setup.sh).
export ORA_HOST="ORACLE_PUBLIC_IPV4"
export ORA_DIRECT="postgresql://app:PW@${ORA_HOST}:5432/finance?sslmode=require"
export ORA_POOLED="postgresql://app:PW@${ORA_HOST}:6432/finance?sslmode=require"

# ── Destination C: Oracle Object Storage (S3-compat) — ALL buckets move here ───
export OCI_S3_ENDPOINT="https://NAMESPACE.compat.objectstorage.REGION.oraclecloud.com"
export OCI_S3_REGION="REGION"
export OCI_S3_ACCESS_KEY_ID="oci-customer-secret-key-id"
export OCI_S3_SECRET_ACCESS_KEY="oci-customer-secret-key"
# Supabase S3-compat source creds (Supabase dashboard → Storage → S3 access keys)
export SB_S3_ENDPOINT="https://rdtvemrbbsmiagbyvgzz.supabase.co/storage/v1/s3"
export SB_S3_REGION="REGION"
export SB_S3_ACCESS_KEY_ID="supabase-s3-access-key"
export SB_S3_SECRET_ACCESS_KEY="supabase-s3-secret"

# ── Table inventory (SSOT: 00.finance.plan.md §5.1) ───────────────────────────
export BLOG_TABLES="users posts categories files tags post_tags post_categories invites post_favorites post_likes comments"
export FINANCE_TABLES="market_snapshots market_history tracked_symbols market_rankings symbol_fundamentals error_log batch_log sec_filings sec_holdings security_map fund_registry politician_registry politician_trades politician_committees committee_sector_map signal_backtest gex_daily"
# mv_sec_new_positions is a MATERIALIZED VIEW — regenerated by 32_refresh_mv.sql, not dumped as data.

export BUCKETS="blog.prettylog market-archive sec-archive"

# ── Working dir for dump artifacts ────────────────────────────────────────────
export DUMP_DIR="${DUMP_DIR:-$(cd "$(dirname "$0")" && pwd)/_dumps}"
mkdir -p "$DUMP_DIR"

# Helper: turn a space-separated table list into repeated `-t name` flags.
_t_flags() { local out=""; for t in $1; do out="$out -t $t"; done; echo "$out"; }
export -f _t_flags
