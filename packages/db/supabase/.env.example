# ==============================================================================
# Supabase project / CLI — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.
#
# These overlap with apps/dashboard_server/.env — the CLI reads from this dir;
# keep them in sync. When you change a value here, update the server .env too.
#
# Values are found in the Supabase Dashboard:
#   https://supabase.com/dashboard → select your project → Project Settings
#
# CLOUD is the default below. For LOCAL `supabase start`, use (per config.toml):
#   SUPABASE_PROJECT_ID=dashboard_server
#   POSTGRES_PASSWORD=postgres
#   SUPABASE_URL=http://127.0.0.1:54321
#   POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   publishable/secret keys → copy from `supabase status` (sb_publishable_... / sb_secret_...)

# ------------------------------------------------------------------------------
# Project ref — unique identifier for your Supabase project.
# Dashboard: Settings → General → Reference ID
# (key name is SUPABASE_PROJECT_ID, not SUPABASE_PROJECT_REF)
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_ID=your-project-id

# ------------------------------------------------------------------------------
# DB password — the password you set when creating the project.
# Dashboard: Settings → Database → Database password
# ------------------------------------------------------------------------------
POSTGRES_PASSWORD=your-db-password

# ------------------------------------------------------------------------------
# Supabase project URL — used by the JS client SDK and server-side calls.
# Dashboard: Settings → API → Project URL
# ------------------------------------------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co

# ------------------------------------------------------------------------------
# Publishable key — safe to expose in the browser / CLI operations that only
# need anon/public-level access.
# Dashboard: Settings → API → Project API keys → public (publishable) key
# ------------------------------------------------------------------------------
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ------------------------------------------------------------------------------
# Service role / secret key — SERVER ONLY. Never expose to the browser.
# Used for admin-level operations that bypass Row Level Security (RLS).
# Dashboard: Settings → API → Project API keys → secret key
# Supabase 2024+ naming: SUPABASE_SECRET_KEY (formerly SUPABASE_SERVICE_ROLE_KEY).
# ------------------------------------------------------------------------------
SUPABASE_SECRET_KEY=sb_secret_...

# ------------------------------------------------------------------------------
# Connection strings (Vercel ↔ Supabase integration names — the only DB vars used)
#
# POSTGRES_URL_NON_POOLING (port 5432) — use for:
#   • supabase db push / pull (migrations via Supabase CLI)
#   • psql / pgAdmin / manual administration
#   • long-lived server processes with persistent connections
#
# POSTGRES_URL (port 6543, PgBouncer transaction pooler) — use for:
#   • runtime queries from apps/dashboard_server
#   • Vercel serverless functions (short-lived, high connection churn)
#   → this value should match POSTGRES_URL in apps/dashboard_server/.env
#
# Dashboard: Settings → Database → Connection string
#   → toggle "Transaction pooler" for 6543, "Direct connection" for 5432
# ------------------------------------------------------------------------------

# Direct connection — migrations, CLI, psql (port 5432)
POSTGRES_URL_NON_POOLING=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Transaction pooler — runtime queries from the Express server (port 6543)
POSTGRES_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
