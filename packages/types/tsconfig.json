{
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "target": "ES2020",
        "lib": ["ES2020"],
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src"],
    "exclude": ["dist", "node_modules"]
}
