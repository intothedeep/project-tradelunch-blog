{
    "name": "with-tailwind",
    "private": true,
    "packageManager": "pnpm@9.5.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "dev:web": "pnpm --filter dashboard_client_web dev",
        "dev:server": "pnpm --filter dashboard_server dev",
        "dev:agent": "pnpm --filter blog_agent start",
        "test:agent": "pnpm --filter blog_agent test",
        "lint": "turbo run lint",
        "check-types": "turbo run check-types",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check:schema": "diff apps/dashboard_server/schema/tradelunch.schema.sql apps/blog_agent/schema/tradelunch.schema.sql && echo 'schema in sync' || (echo 'SCHEMA DRIFT' && exit 1)"
    },
    "devDependencies": {
        "@jest/globals": "^30.4.1",
        "@types/jest": "^30.0.0",
        "eslint": "^9.39.4",
        "jest": "^30.4.2",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "turbo": "^2.10.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=20"
    }
}
